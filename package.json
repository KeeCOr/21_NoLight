{
  "name": "21-nl",
  "version": "0.1.0",
  "description": "수묵화 액션 플랫포머",
  "author": "오진우",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "jest"
  },
  "dependencies": {
    "phaser": "^3.60.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "build": {
    "appId": "com.21nl.game",
    "productName": "21NL",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "index.html",
      "src/**/*",
      "assets/**/*",
      "node_modules/phaser/dist/phaser.min.js"
    ],
    "win": {
      "target": ["portable"]
    },
    "portable": {
      "artifactName": "21NL_v${version}_portable.exe"
    }
  }
}
